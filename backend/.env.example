# ── App ─────────────────────────────────────────────────────────
DEBUG=false
APP_URL=https://yourdomain.com

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=videograb
POSTGRES_USER=videograb
POSTGRES_PASSWORD=замени-на-сложный-пароль

DATABASE_URL=postgresql+asyncpg://videograb:замени-на-сложный-пароль@db:5432/videograb
DATABASE_URL_SYNC=postgresql://videograb:замени-на-сложный-пароль@db:5432/videograb

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Auth ─────────────────────────────────────────────────────────
# Сгенерируй: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-64-символа

# ── Email — Resend ───────────────────────────────────────────────
# Бесплатно: resend.com → Add API Key → скопируй
# 3000 писем/мес бесплатно, потом $20/мес за 50k
RESEND_API_KEY=re_...
EMAIL_FROM=VideoGrab <noreply@yourdomain.com>

# ── Downloads ────────────────────────────────────────────────────
DOWNLOAD_DIR=/tmp/videograb
FILE_TTL_HOURS=2

# ── Plans (Free tier) ────────────────────────────────────────────
FREE_DAILY_LIMIT=3
FREE_MAX_HEIGHT=720
