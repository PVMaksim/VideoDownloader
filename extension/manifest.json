{
  "manifest_version": 3,
  "name": "VideoDownloader",
  "version": "1.0.3",
  "description": "Скачивай видео с GetCourse и других платформ",
  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "notifications",
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://videodownloader.neoxis.store:8450/",
    "http://localhost:8000/",
    "<all_urls>",
    "http://localhost:8301/",
    "http://127.0.0.1:8301/",
    "http://193.242.109.48:8301/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://videodownloader.neoxis.store:8450 https://neoxis.store http://localhost:8301 http://193.242.109.48:8301"
  }
}