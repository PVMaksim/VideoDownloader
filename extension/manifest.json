{
  "manifest_version": 3,
  "name": "VideoGrab",
  "version": "0.9.0",
  "description": "Скачивай видео с GetCourse и других платформ",

  "permissions": [
    "webRequest", "cookies", "storage", "notifications",
    "activeTab", "tabs", "scripting", "alarms", "downloads"
  ],

  "host_permissions": ["<all_urls>"],

  "background": { "service_worker": "background.js" },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options/options.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
